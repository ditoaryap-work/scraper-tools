---
import Layout from '../layouts/Layout.astro';
---

<Layout title="OmniExtract | Free Web Scraper">
  <div class="max-w-4xl mx-auto px-6 py-10 md:py-20">
    <!-- Header -->
    <header class="flex justify-between items-center mb-20 border-b border-slate-800 pb-6">
      <div class="flex items-center gap-2">
        <svg class="w-8 h-8 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
        <h1 class="text-2xl font-bold tracking-tight text-white">OmniExtract</h1>
      </div>
      <div class="flex gap-4 items-center">
        <span class="text-sm font-medium px-3 py-1 bg-slate-800 text-blue-400 rounded-full">100% Free</span>
        <a href="https://github.com/ditoaryap-work/scraper-tools" target="_blank" rel="noopener noreferrer" class="text-slate-400 hover:text-white transition-colors text-sm font-medium">GitHub</a>
      </div>
    </header>

    <!-- Hero -->
    <main>
      <div class="mb-14 text-center max-w-2xl mx-auto">
        <h2 class="text-4xl md:text-6xl font-extrabold tracking-tight mb-6 leading-tight bg-gradient-to-r from-blue-400 to-indigo-400 text-transparent bg-clip-text">Any Website to Clean Data.</h2>
        <p class="text-slate-400 text-lg md:text-xl">Extract markdown, raw HTML, images, and full design systems. No limits, no credits, no login required.</p>
      </div>

      <!-- Main Panel -->
      <div class="bg-slate-900 border border-slate-800 rounded-2xl p-6 md:p-8 shadow-2xl">
        
        <!-- Input Area -->
        <div class="relative mb-8">
          <label for="url-input" class="block text-sm font-medium text-slate-400 mb-2">Target URL</label>
          <div class="flex flex-col md:flex-row gap-3">
            <input 
              type="url" 
              id="url-input"
              class="flex-1 bg-slate-950 border border-slate-700 rounded-xl py-4 px-5 text-white placeholder-slate-600 focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500 transition-all"
              placeholder="https://example.com"
            />
            <button 
              id="submit-btn"
              class="w-full md:w-auto bg-blue-600 hover:bg-blue-500 disabled:opacity-50 disabled:cursor-not-allowed text-white font-semibold py-4 px-8 rounded-xl transition-all shadow-lg shadow-blue-900/20 whitespace-nowrap"
            >
              <span id="submit-text">Extract Data</span>
            </button>
          </div>
        </div>

        <!-- Mode Selector -->
        <div>
          <label class="block text-sm font-medium text-slate-400 mb-3">Extraction Mode</label>
          <div class="grid grid-cols-2 md:grid-cols-3 gap-3" id="tools-grid">
            <button class="tool-btn active" data-mode="crawl">
              <div class="font-semibold text-base mb-1">Crawl Website</div>
              <div class="text-xs opacity-70">Deep text extract</div>
            </button>
            <button class="tool-btn" data-mode="design">
              <div class="font-semibold text-base mb-1">Create Design MD</div>
              <div class="text-xs opacity-70">Generate DESIGN.md</div>
            </button>
            <button class="tool-btn" data-mode="markdown">
              <div class="font-semibold text-base mb-1">Scrape Markdown</div>
              <div class="text-xs opacity-70">LLM-ready text</div>
            </button>
            <button class="tool-btn" data-mode="html">
              <div class="font-semibold text-base mb-1">Scrape HTML</div>
              <div class="text-xs opacity-70">Raw DOM structure</div>
            </button>
            <button class="tool-btn" data-mode="images">
              <div class="font-semibold text-base mb-1">Scrape Images</div>
              <div class="text-xs opacity-70">Extract all media URLs</div>
            </button>
            <button class="tool-btn" data-mode="styleguide">
              <div class="font-semibold text-base mb-1">Extract Styleguide</div>
              <div class="text-xs opacity-70">Colors & Fonts</div>
            </button>
          </div>
        </div>

      </div>

      <!-- Result Area (Text modes: crawl, markdown, html) -->
      <div id="result-container" class="mt-8 hidden">
        <div class="bg-slate-900 border border-slate-800 rounded-2xl overflow-hidden shadow-xl">
          <div class="flex justify-between items-center px-4 py-3 bg-slate-950 border-b border-slate-800">
            <div class="flex items-center gap-2">
              <div class="w-3 h-3 rounded-full bg-red-500/80"></div>
              <div class="w-3 h-3 rounded-full bg-yellow-500/80"></div>
              <div class="w-3 h-3 rounded-full bg-green-500/80"></div>
              <span id="output-filename" class="ml-2 text-xs font-mono text-slate-500">output.txt</span>
            </div>
            <div class="flex gap-2">
              <button id="download-btn" class="text-xs font-medium text-emerald-400 hover:text-emerald-300 bg-emerald-500/10 hover:bg-emerald-500/20 px-3 py-1.5 rounded-lg transition-colors">⬇ Download</button>
              <button id="copy-btn" class="text-xs font-medium text-blue-400 hover:text-blue-300 bg-blue-500/10 hover:bg-blue-500/20 px-3 py-1.5 rounded-lg transition-colors">Copy Output</button>
            </div>
          </div>
          <pre class="p-6 overflow-x-auto text-sm font-mono text-slate-300 max-h-[600px] overflow-y-auto leading-relaxed"><code id="result-code"></code></pre>
        </div>
      </div>

      <!-- Image Gallery -->
      <div id="gallery-container" class="mt-8 hidden">
        <div class="bg-slate-900 border border-slate-800 rounded-2xl overflow-hidden shadow-xl">
          <div class="flex justify-between items-center px-4 py-3 bg-slate-950 border-b border-slate-800">
            <span id="gallery-count" class="text-sm font-medium text-slate-400">0 images found</span>
            <div class="flex gap-2">
              <button id="download-zip-btn" class="text-xs font-medium text-purple-400 hover:text-purple-300 bg-purple-500/10 hover:bg-purple-500/20 px-3 py-1.5 rounded-lg transition-colors">⬇ Download All (ZIP)</button>
              <button id="download-images-btn" class="text-xs font-medium text-emerald-400 hover:text-emerald-300 bg-emerald-500/10 hover:bg-emerald-500/20 px-3 py-1.5 rounded-lg transition-colors">⬇ Download URLs</button>
            </div>
          </div>
          <div id="gallery-grid" class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-3 p-4"></div>
          <div id="gallery-pagination" class="flex justify-center items-center gap-2 p-4 border-t border-slate-800"></div>
        </div>
      </div>

      <!-- Lightbox -->
      <div id="lightbox" class="fixed inset-0 z-50 bg-black/90 flex items-center justify-center hidden cursor-zoom-out" onclick="this.classList.add('hidden')">
        <img id="lightbox-img" class="max-w-[90vw] max-h-[90vh] object-contain rounded-lg shadow-2xl" />
      </div>

      <!-- Design System View -->
      <div id="design-container" class="mt-8 hidden">
        <div class="bg-slate-900 border border-slate-800 rounded-2xl overflow-hidden shadow-xl">
          <div class="flex justify-between items-center px-4 py-3 bg-slate-950 border-b border-slate-800">
            <span class="text-sm font-medium text-slate-400">🎨 Design System</span>
            <div class="flex gap-2">
              <button id="dl-design-md" class="text-xs font-medium text-emerald-400 hover:text-emerald-300 bg-emerald-500/10 hover:bg-emerald-500/20 px-3 py-1.5 rounded-lg transition-colors">⬇ DESIGN.md</button>
              <button id="dl-css-tokens" class="text-xs font-medium text-blue-400 hover:text-blue-300 bg-blue-500/10 hover:bg-blue-500/20 px-3 py-1.5 rounded-lg transition-colors">⬇ tokens.css</button>
              <button id="dl-tailwind" class="text-xs font-medium text-purple-400 hover:text-purple-300 bg-purple-500/10 hover:bg-purple-500/20 px-3 py-1.5 rounded-lg transition-colors">⬇ tailwind.config</button>
            </div>
          </div>
          <div id="design-content" class="p-6 space-y-8 max-h-[700px] overflow-y-auto"></div>
        </div>
      </div>
    </main>
  </div>
</Layout>

<style is:global>
  @import "../styles/global.css";
  .tool-btn {
    @apply bg-slate-950 border border-slate-800 text-slate-400 p-4 rounded-xl text-left hover:bg-slate-800 hover:border-slate-700 transition-all focus:outline-none focus:ring-2 focus:ring-slate-700;
  }
  .tool-btn.active {
    @apply bg-blue-500/10 border-blue-500/50 text-blue-400 shadow-inner;
  }
  .gallery-card {
    @apply relative rounded-xl overflow-hidden bg-slate-950 border border-slate-800 aspect-square cursor-pointer transition-all hover:border-blue-500/50 hover:shadow-lg;
  }
  .gallery-card img {
    @apply w-full h-full object-cover transition-transform duration-300;
  }
  .gallery-card:hover img { transform: scale(1.05); }
  .gallery-card .overlay {
    @apply absolute inset-0 flex items-end p-2 opacity-0 transition-opacity;
    background: linear-gradient(to top, rgba(0,0,0,0.7), transparent 60%);
  }
  .gallery-card:hover .overlay { opacity: 1; }
  .gallery-card .overlay span {
    @apply text-[10px] text-white/80 truncate font-mono;
  }
  .dl-img-btn {
    @apply shrink-0 ml-2 w-7 h-7 flex items-center justify-center rounded-lg bg-white/20 hover:bg-white/30 text-white text-xs transition-colors backdrop-blur-sm;
  }
  .page-btn {
    @apply px-3 py-1.5 rounded-lg text-sm font-medium transition-colors;
  }
  .page-btn.active {
    @apply bg-blue-600 text-white;
  }
  .page-btn:not(.active) {
    @apply bg-slate-800 text-slate-400 hover:bg-slate-700 hover:text-white;
  }
  .color-swatch {
    @apply rounded-xl overflow-hidden border border-slate-800;
  }
  .color-swatch .preview {
    @apply h-16 w-full;
  }
  .color-swatch .info {
    @apply p-3 bg-slate-950 space-y-1;
  }
  .font-preview {
    @apply bg-slate-950 border border-slate-800 rounded-xl p-4;
  }
</style>

<script>
  declare const JSZip: any;
  let activeMode = 'crawl';
  let currentFilename = 'output.txt';
  let galleryImages: { src: string; alt: string }[] = [];
  let galleryPage = 0;
  const IMAGES_PER_PAGE = 12;
  let designData: any = null;

  const $ = (id: string) => document.getElementById(id);
  const buttons = document.querySelectorAll('.tool-btn');
  const submitText = $('submit-text')!;
  const submitBtn = $('submit-btn') as HTMLButtonElement;
  const urlInput = $('url-input') as HTMLInputElement;
  const resultContainer = $('result-container')!;
  const resultCode = $('result-code')!;
  const copyBtn = $('copy-btn')!;
  const downloadBtn = $('download-btn')!;
  const outputFilename = $('output-filename')!;
  const galleryContainer = $('gallery-container')!;
  const galleryGrid = $('gallery-grid')!;
  const galleryCount = $('gallery-count')!;
  const galleryPagination = $('gallery-pagination')!;
  const downloadImagesBtn = $('download-images-btn')!;
  const designContainer = $('design-container')!;
  const designContent = $('design-content')!;

  function hideAll() {
    resultContainer.classList.add('hidden');
    galleryContainer.classList.add('hidden');
    designContainer.classList.add('hidden');
  }

  const modeExt: Record<string, string> = { crawl:'md', markdown:'md', html:'html', images:'txt', styleguide:'md', design:'md' };

  function genFilename(url: string, mode: string): string {
    let domain = 'unknown';
    try { domain = new URL(url).hostname.replace(/^www\./,'').replace(/[^a-zA-Z0-9.-]/g,'_'); } catch {}
    const date = new Date().toISOString().split('T')[0];
    const prefix = mode === 'design' ? 'DESIGN' : mode;
    return `${prefix}_${domain}_${date}.${modeExt[mode]||'txt'}`;
  }

  function downloadFile(content: string, filename: string, type = 'text/plain') {
    const blob = new Blob([content], { type: `${type};charset=utf-8` });
    const a = document.createElement('a');
    a.href = URL.createObjectURL(blob);
    a.download = filename;
    document.body.appendChild(a); a.click(); document.body.removeChild(a);
    URL.revokeObjectURL(a.href);
  }

  function flashBtn(btn: HTMLElement, text: string) {
    const orig = btn.textContent;
    btn.textContent = text;
    setTimeout(() => { btn.textContent = orig; }, 2000);
  }

  // --- Security helpers ---
  function escapeHtml(str: string): string {
    return str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;').replace(/'/g, '&#039;');
  }

  function safeUrl(url: string): string {
    try {
      const parsed = new URL(url);
      if (!['http:', 'https:'].includes(parsed.protocol)) return '';
      return parsed.href;
    } catch { return ''; }
  }

  function isValidHex(hex: string): boolean {
    return /^#[0-9A-Fa-f]{6}$/.test(hex);
  }

  // Tool selection
  buttons.forEach(btn => {
    btn.addEventListener('click', (e) => {
      buttons.forEach(b => b.classList.remove('active'));
      (e.currentTarget as HTMLElement).classList.add('active');
      activeMode = (e.currentTarget as HTMLButtonElement).dataset.mode || 'crawl';
    });
  });

  // Submit
  submitBtn.addEventListener('click', async () => {
    const url = urlInput.value.trim();
    if (!url) { alert('Please enter a valid URL'); return; }

    submitBtn.disabled = true;
    submitText.textContent = 'Extracting...';
    hideAll();

    try {
      const resp = await fetch('/api/scrape', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ url, mode: activeMode })
      });
      const data = await resp.json();
      currentFilename = genFilename(url, activeMode);

      if (data.error) {
        resultCode.textContent = `⚠ Error: ${data.error}`;
        resultContainer.classList.remove('hidden');
        return;
      }

      // --- IMAGES mode: gallery view ---
      if (data.type === 'images' && data.images) {
        galleryImages = data.images;
        galleryPage = 0;
        galleryCount.textContent = `${data.count} images found`;
        renderGallery();
        galleryContainer.classList.remove('hidden');
        return;
      }

      // --- DESIGN / STYLEGUIDE mode: visual view ---
      if (data.type === 'design' || data.type === 'styleguide') {
        designData = data;
        renderDesign(data);
        designContainer.classList.remove('hidden');
        return;
      }

      // --- TEXT modes: code block ---
      const text = data.result || JSON.stringify(data, null, 2);
      resultCode.textContent = text;
      if (outputFilename) outputFilename.textContent = currentFilename;
      resultContainer.classList.remove('hidden');

    } catch (err) {
      alert('Network Error. Check your connection and try again.');
    } finally {
      submitBtn.disabled = false;
      submitText.textContent = 'Extract Data';
    }
  });

  // --- Image Gallery ---
  const PROXY = '/api/proxy-image?url=';

  function getImageName(src: string): string {
    try {
      const path = new URL(src).pathname;
      const name = path.split('/').pop() || 'image';
      return name.length > 40 ? name.slice(0, 37) + '...' : name;
    } catch { return 'image.jpg'; }
  }

  function renderGallery() {
    const start = galleryPage * IMAGES_PER_PAGE;
    const pageImages = galleryImages.slice(start, start + IMAGES_PER_PAGE);
    galleryGrid.innerHTML = '';

    pageImages.forEach((img) => {
      const card = document.createElement('div');
      card.className = 'gallery-card';
      const name = getImageName(img.src);
      const safeSrc = safeUrl(img.src);
      const safeAlt = escapeHtml(img.alt || '');
      const safeName = escapeHtml(name);
      if (!safeSrc) return; // skip images with invalid URLs
      card.innerHTML = `
        <img src="${safeSrc}" alt="${safeAlt}" loading="lazy" onerror="this.parentElement.style.display='none'" />
        <div class="overlay">
          <span class="flex-1">${safeAlt || safeName}</span>
          <button class="dl-img-btn" title="Download image">⬇</button>
        </div>
      `;
      const dlBtn = card.querySelector('.dl-img-btn')!;

      // Click card → lightbox (but not if clicking download button)
      card.addEventListener('click', (e) => {
        if ((e.target as HTMLElement).closest('.dl-img-btn')) return;
        openLightbox(img.src);
      });

      // Click download → fetch via proxy and save
      dlBtn.addEventListener('click', async (e) => {
        e.stopPropagation();
        const btn = e.currentTarget as HTMLElement;
        btn.textContent = '⏳';
        try {
          const resp = await fetch(PROXY + encodeURIComponent(img.src));
          const blob = await resp.blob();
          const ext = blob.type.split('/')[1]?.split(';')[0] || 'jpg';
          const fname = name.endsWith('.') ? `${name}${ext}` : name;
          const a = document.createElement('a');
          a.href = URL.createObjectURL(blob);
          a.download = fname;
          document.body.appendChild(a); a.click(); document.body.removeChild(a);
          btn.textContent = '✓';
          setTimeout(() => { btn.textContent = '⬇'; }, 1500);
        } catch {
          btn.textContent = '✗';
          setTimeout(() => { btn.textContent = '⬇'; }, 1500);
        }
      });

      galleryGrid.appendChild(card);
    });

    renderPagination();
  }

  function renderPagination() {
    const totalPages = Math.ceil(galleryImages.length / IMAGES_PER_PAGE);
    galleryPagination.innerHTML = '';
    if (totalPages <= 1) return;

    const mkBtn = (label: string, page: number, disabled = false) => {
      const btn = document.createElement('button');
      btn.className = `page-btn ${page === galleryPage ? 'active' : ''}`;
      btn.textContent = label;
      btn.disabled = disabled;
      if (!disabled) btn.addEventListener('click', () => { galleryPage = page; renderGallery(); });
      return btn;
    };

    galleryPagination.appendChild(mkBtn('←', galleryPage - 1, galleryPage === 0));

    const maxVisible = 7;
    let startP = Math.max(0, galleryPage - Math.floor(maxVisible / 2));
    let endP = Math.min(totalPages, startP + maxVisible);
    if (endP - startP < maxVisible) startP = Math.max(0, endP - maxVisible);

    if (startP > 0) { galleryPagination.appendChild(mkBtn('1', 0)); if (startP > 1) galleryPagination.appendChild(Object.assign(document.createElement('span'), { textContent: '...', className: 'text-slate-600 px-1' })); }
    for (let i = startP; i < endP; i++) galleryPagination.appendChild(mkBtn(`${i+1}`, i));
    if (endP < totalPages) { if (endP < totalPages - 1) galleryPagination.appendChild(Object.assign(document.createElement('span'), { textContent: '...', className: 'text-slate-600 px-1' })); galleryPagination.appendChild(mkBtn(`${totalPages}`, totalPages - 1)); }

    galleryPagination.appendChild(mkBtn('→', galleryPage + 1, galleryPage === totalPages - 1));
  }

  function openLightbox(src: string) {
    const lb = $('lightbox')!;
    ($('lightbox-img') as HTMLImageElement).src = src;
    lb.classList.remove('hidden');
  }

  downloadImagesBtn.addEventListener('click', () => {
    const urls = galleryImages.map(img => img.src).join('\n');
    downloadFile(urls, currentFilename);
    flashBtn(downloadImagesBtn, '✓ Downloaded!');
  });

  // Download All as ZIP
  const downloadZipBtn = $('download-zip-btn')! as HTMLButtonElement;
  downloadZipBtn.addEventListener('click', async () => {
    if (!galleryImages.length) return;
    downloadZipBtn.disabled = true;
    downloadZipBtn.textContent = '⏳ Building ZIP...';

    try {
      const zip = new JSZip();
      const total = galleryImages.length;
      let done = 0;

      // Fetch all images via proxy
      const promises = galleryImages.map(async (img, idx) => {
        try {
          const resp = await fetch(PROXY + encodeURIComponent(img.src));
          if (!resp.ok) return;
          const blob = await resp.blob();
          const ext = blob.type.split('/')[1]?.split(';')[0] || 'jpg';
          const name = getImageName(img.src);
          const fname = `${String(idx + 1).padStart(3, '0')}_${name.includes('.') ? name : name + '.' + ext}`;
          zip.file(fname, blob);
        } catch {}
        done++;
        downloadZipBtn.textContent = `⏳ ${done}/${total}`;
      });

      await Promise.all(promises);
      downloadZipBtn.textContent = '⏳ Compressing...';

      const zipBlob = await zip.generateAsync({ type: 'blob' });
      const a = document.createElement('a');
      a.href = URL.createObjectURL(zipBlob);
      a.download = currentFilename.replace('.txt', '.zip');
      document.body.appendChild(a); a.click(); document.body.removeChild(a);

      downloadZipBtn.textContent = '✓ Done!';
      setTimeout(() => { downloadZipBtn.textContent = '⬇ Download All (ZIP)'; downloadZipBtn.disabled = false; }, 2000);
    } catch {
      downloadZipBtn.textContent = '✗ Failed';
      setTimeout(() => { downloadZipBtn.textContent = '⬇ Download All (ZIP)'; downloadZipBtn.disabled = false; }, 2000);
    }
  });

  // --- Design System View ---
  function renderDesign(data: any) {
    const colors = data.data?.colors || data.colors || [];
    const fonts = data.data?.fonts || data.fonts || [];
    let html = '';

    // Colors section
    if (colors.length) {
      const groups: Record<string, typeof colors> = {};
      colors.forEach((c: any) => { const cat = c.category || 'accent'; if (!groups[cat]) groups[cat] = []; groups[cat].push(c); });

      html += '<div><h3 class="text-lg font-bold text-white mb-4">🎨 Color Palette</h3>';
      Object.entries(groups).forEach(([group, cols]) => {
        html += `<h4 class="text-sm font-semibold text-slate-400 mb-3 mt-4 capitalize">${escapeHtml(group)} Colors</h4>`;
        html += '<div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-3">';
        cols.forEach((c: any) => {
          const hex = isValidHex(c.hex) ? c.hex : '#888888';
          html += `<div class="color-swatch">
            <div class="preview" style="background:${hex}"></div>
            <div class="info">
              <div class="text-sm font-mono font-bold text-white">${escapeHtml(c.hex || '')}</div>
              <div class="text-xs text-slate-500 font-mono">${escapeHtml(c.rgb || '')}</div>
              <div class="text-xs text-slate-500 font-mono">${escapeHtml(c.hsl || '')}</div>
            </div>
          </div>`;
        });
        html += '</div>';
      });
      html += '</div>';
    }

    // Typography section
    if (fonts.length) {
      html += '<div><h3 class="text-lg font-bold text-white mb-4">🔤 Typography</h3>';
      fonts.forEach((f: any, i: number) => {
        const role = i === 0 ? 'Primary' : i === 1 ? 'Secondary' : `Fallback ${i}`;
        const safeFamily = escapeHtml(f.family || 'sans-serif');
        // Sanitize font-family for CSS: only allow alphanumeric, spaces, hyphens
        const cssFamily = (f.family || 'sans-serif').replace(/[^a-zA-Z0-9\s\-]/g, '');
        html += `<div class="font-preview mb-4">
          <div class="flex justify-between items-start mb-3">
            <div><span class="text-white font-bold text-lg" style="font-family:'${cssFamily}'">${safeFamily}</span>
            <span class="ml-2 text-xs text-blue-400 bg-blue-500/10 px-2 py-0.5 rounded-full">${role}</span></div>
            <div class="text-xs text-slate-500">${escapeHtml((f.contexts || []).join(', '))}</div>
          </div>
          <div class="text-2xl text-slate-300 mb-2" style="font-family:'${cssFamily}'">The quick brown fox jumps over the lazy dog</div>
          <div class="flex flex-wrap gap-2 mt-3">
            ${(f.weights||[]).map((w: string) => `<span class="text-xs bg-slate-800 text-slate-400 px-2 py-1 rounded">Weight: ${escapeHtml(String(w))}</span>`).join('')}
            ${(f.sizes||[]).map((s: string) => `<span class="text-xs bg-slate-800 text-slate-400 px-2 py-1 rounded">${escapeHtml(String(s))}</span>`).join('')}
          </div>
        </div>`;
      });
      html += '</div>';
    }

    // Spacing section
    const spacing = data.data?.spacing || data.spacing || [];
    if (spacing.length) {
      html += '<div><h3 class="text-lg font-bold text-white mb-4">📏 Spacing</h3>';
      html += '<div class="flex flex-wrap gap-2">';
      spacing.forEach((s: string, i: number) => {
        const px = parseFloat(s);
        if (isNaN(px)) return;
        html += `<div class="bg-slate-950 border border-slate-800 rounded-lg p-3 text-center min-w-[80px]">
          <div class="h-2 bg-blue-500 rounded mb-2" style="width:${Math.min(px, 80)}px;margin:0 auto"></div>
          <div class="text-xs font-mono text-white">${escapeHtml(String(s))}</div>
          <div class="text-[10px] text-slate-500">space-${i+1}</div>
        </div>`;
      });
      html += '</div></div>';
    }

    designContent.innerHTML = html;
  }

  // Design download buttons
  $('dl-design-md')!.addEventListener('click', () => {
    if (designData?.markdown) downloadFile(designData.markdown, currentFilename);
    flashBtn($('dl-design-md')!, '✓ Done!');
  });
  $('dl-css-tokens')!.addEventListener('click', () => {
    if (designData?.cssTokens) downloadFile(designData.cssTokens, currentFilename.replace('.md', '.css'));
    flashBtn($('dl-css-tokens')!, '✓ Done!');
  });
  $('dl-tailwind')!.addEventListener('click', () => {
    if (designData?.tailwindConfig) downloadFile(designData.tailwindConfig, 'tailwind.config.js');
    flashBtn($('dl-tailwind')!, '✓ Done!');
  });

  // Copy & Download (text modes)
  copyBtn.addEventListener('click', () => {
    if (resultCode.textContent) { navigator.clipboard.writeText(resultCode.textContent); flashBtn(copyBtn, '✓ Copied!'); }
  });
  downloadBtn.addEventListener('click', () => {
    if (resultCode.textContent) { downloadFile(resultCode.textContent, currentFilename); flashBtn(downloadBtn, '✓ Downloaded!'); }
  });
</script>